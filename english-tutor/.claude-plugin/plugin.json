{
  "name": "english-tutor",
  "version": "0.2.0",
  "description": "Real-time English learning assistant for Claude Code that corrects your English while you develop",
  "author": {
    "name": "ezotaka",
    "email": "",
    "url": "https://github.com/ezotaka"
  },
  "repository": "https://github.com/ezotaka/claude-plugins",
  "license": "MIT",
  "keywords": ["english", "learning", "education", "language", "correction"],
  "mcpServers": {
    "english-tutor": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/server.js"],
      "env": {
        "ENGLISH_TUTOR_DB": "${HOME}/.claude/english-tutor/english_study.db"
      }
    }
  }
}
